FROM node:22-alpine

RUN apk add --no-cache openjdk17-jre-headless bash

RUN npm install -g firebase-tools

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 3000 4000 5001 8080 9099 9199

CMD ["sh", "-c", "firebase emulators:start --project lupyx-talent & npm run dev -- --hostname 0.0.0.0"]
