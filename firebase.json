{
  "hosting": {
    "public": "out",
    "cleanUrls": true,
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=604800, immutable" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      { "source": "/sitemap.xml", "function": "sitemap" },
      { "source": "/api/jobs", "function": "listJobs" },
      { "source": "/api/subscribe", "function": "subscribe" },
      { "source": "/api/applications", "function": "submitApplication" },
      { "source": "/api/my-applications", "function": "listApplications" },
      { "source": "/api/my-applications/withdraw", "function": "withdrawApplication" },
      { "source": "/api/user/profile", "function": "userProfile" },
      { "source": "/api/notifications", "function": "getNotifications" },
      { "source": "/api/notifications/read", "function": "markNotificationRead" },
      { "source": "/api/admin/jobs/list", "function": "adminListJobs" },
      { "source": "/api/admin/usage", "function": "adminUsage" },
      { "source": "/api/admin/dashboard", "function": "adminDashboard" },
      { "source": "/api/admin/jobs/create", "function": "createJob" },
      { "source": "/api/admin/jobs/update", "function": "updateJob" },
      { "source": "/api/admin/jobs/status", "function": "updateJobStatus" },
      { "source": "/api/admin/applications", "function": "adminListApplications" },
      { "source": "/api/admin/applications/status", "function": "updateApplicationStatus" },
      { "source": "/api/admin/applications/notes", "function": "addInterviewNotes" },
      { "source": "/api/admin/applications/rounds", "function": "manageInterviewRounds" },
      { "source": "/api/admin/applications/fraud", "function": "fraudAnalysis" },
      { "source": "/api/admin/users", "function": "listUsers" },
      { "source": "/api/admin/users/role", "function": "updateUserRole" },
      { "source": "/api/admin/users/status", "function": "toggleUserStatus" },
      { "source": "/api/admin/allowlist", "function": "getAllowlist" },
      { "source": "/api/admin/allowlist/add", "function": "addAllowlistEmail" },
      { "source": "/api/admin/allowlist/remove", "function": "removeAllowlistEmail" },
      { "source": "/api/admin/applications/comment", "function": "addComment" },
      { "source": "/api/admin/applications/detail", "function": "getApplicationDetail" },
      { "source": "/api/admin/applications/analyze-cv", "function": "analyzeCv" },
      { "source": "/api/admin/cv/download", "function": "downloadCv" },
      { "source": "/api/admin/applications/delete", "function": "deleteApplication" },
      { "source": "/api/admin/candidates", "function": "listCandidates" },
      { "source": "/api/admin/candidates/add", "function": "addCandidate" },
      { "source": "/api/admin/candidates/delete", "function": "deleteCandidate" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5002 },
    "ui": { "enabled": true, "port": 4000 }
  }
}
